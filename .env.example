# Copy to .env only if you want to override defaults. `docker compose up` works
# WITHOUT this file — Compose already injects the DB/Redis URLs.
#
# The one value worth setting is your OpenAI key so the LLM stages run for real.
# Easiest: `export OPENAI_API_KEY=sk-...` in your shell before `docker compose up`.

# --- Host port for the API (default 8000; change if that port is taken) ---
API_PORT=8000

# --- LLM (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Datastores (defaults match docker-compose service names) ---
DATABASE_URL=postgresql+psycopg://alemeno:alemeno@db:5432/alemeno
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
